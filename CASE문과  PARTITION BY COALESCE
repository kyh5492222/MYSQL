# CASE문과  PARTITION BY COALESCE 이용한 조회문

SELECT * FROM (
    SELECT
        ROW_NUMBER() OVER (
            PARTITION BY COALESCE(A.ORGNLY_WTRQLT_MGT_SN, A.WTRQLT_MGT_SN)
            ORDER BY A.WTRQLT_MGT_SN DESC
        ) AS rnum
      , COUNT(*) OVER() AS TOT_CNT
      , A.WTRQLT_MGT_SN
      , A.UC
      , A.LGDCD
      , A.WTSPL_SN
      , A.WTSPL_SHAPE_CD
      , C.CDVALNM AS WTSPL_SHAPE_NM
      , A.WTRQLT_INSP_DVS_CD
      , D.CDVALNM AS WTRQLT_INSP_DVS_NM
      , A.INSP_REQSTDT
      , A.WTRQLT_INSP_RSLT_CD
      , E.CDVALNM AS WTRQLT_INSP_RSLT_NM
      , A.SMINP_ORGAN_CD
      , F.CDVALNM AS SMINP_ORGAN_NM
      , A.ORGNLY_WTRQLT_MGT_SN
      , A.THEFST_RGST_DTTM
      , A.THEFST_REGSTR_SN
      , A.THEFST_RGST_IP
      , A.FNL_MDFR_DTTM
      , A.FNL_MDFR_SN
      , A.FNL_MDFR_IP
      , CASE B.MDCD
            WHEN '1' THEN '국방부/육직'
            WHEN '2' THEN '육군/군직'
            WHEN '5' THEN '해군'
            WHEN '6' THEN '공군'
            WHEN '7' THEN '합참'
            ELSE '기타'
        END AS MDCD_NM
      , B.ASSGMT_WHL_UNIT_NM
      , G.LGDONG_ADDR_NM
      , G.LGDONGCTCD
      , LEVEL
      , CONNECT_BY_ISLEAF AS ISLEAF
    FROM TNSP_WTRQLT_MGT A
    LEFT JOIN TCIC_UNIT B ON A.UC = B.UC
    LEFT JOIN TCCM_CMNC DIC C
        ON A.WTSPL_SHAPE_CD = C.CDVAL
        AND C.CD_ID = 'WTSPL_SHAPE_CD'
    LEFT JOIN TCCM_CMNC DIC D
        ON A.WTRQLT_INSP_DVS_CD = D.CDVAL
        AND D.CD_ID = 'WTRQLT_INSP_DVS_CD'
    LEFT JOIN TCCM_CMNC DIC E
        ON A.WTRQLT_INSP_RSLT_CD = E.CDVAL
        AND E.CD_ID = 'WTRQLT_INSP_RSLT_CD'
    LEFT JOIN TCCM_CMNC DIC F
        ON A.SMINP_ORGAN_CD = F.CDVAL
        AND F.CD_ID = 'SMINP_ORGAN_CD'
    LEFT JOIN TCCM_LGDONG_ADDR G
        ON A.LGDCD = G.LGDCD
    START WITH A.ORGNLY_WTRQLT_MGT_SN IS NULL
    CONNECT BY PRIOR A.WTRQLT_MGT_SN = A.ORGNLY_WTRQLT_MGT_SN
) Z;
